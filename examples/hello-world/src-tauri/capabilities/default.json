{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the hello-world app",
  "windows": ["main", "*"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:webview:allow-create-webview-window",
    "core:window:allow-close",
    "opener:default",
    "playwright:default"
  ]
}
